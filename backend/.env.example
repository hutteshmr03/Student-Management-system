# Database Configuration
# For local development with docker-compose:
DATABASE_URL=postgresql://postgres:password@localhost:5432/student_dbms
# For production, set this via environment variables (e.g., Railway dashboard)

# Security Configuration
# Generate a strong random key: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Default Admin Credentials (will be seeded into DB on first run)
# IMPORTANT: Change these in production!
ADMIN_EMAIL=admin@school.edu
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=Super Admin

# Database password for docker-compose
DB_PASSWORD=password
